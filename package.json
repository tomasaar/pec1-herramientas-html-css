{
  "name": "pec1-herramientas-html-css",
  "version": "1.0.0",
  "description": "PEC1 UOC Boilerplate uno-page responsive con Sass y Stylelint",
  "main": "src/index.html",
  "scripts": {
    "sass": "node ./node_modules/sass/sass.js src/scss:dist/css --style=compressed",
    "copy-html": "node ./node_modules/cpx/bin/main.js \"src/*.html\" dist/",
    "copy-assets": "node ./node_modules/cpx/bin/main.js \"src/assets/**/*\" dist/assets/",
    "copy-redirects": "node ./node_modules/cpx/bin/main.js \"src/_redirects\" dist/",
    "lint": "stylelint \"src/scss/**/*.scss\"",
    "lint:fix": "stylelint \"src/scss/**/*.scss\" --fix",
    "build": "npm run sass && npm run copy-html && npm run copy-assets && npm run copy-redirects",
    "build:full": "npm run lint && npm run build",
    "start": "npm run build && live-server dist --open=./index.html"
  },
  "devDependencies": {
    "cpx": "^1.5.0",
    "live-server": "^1.2.2",
    "sass": "^1.72.0",
    "stylelint": "^14.16.1",
    "stylelint-config-recommended": "^9.0.0",
    "stylelint-config-standard": "^23.0.0",
    "stylelint-config-standard-scss": "^4.0.0",
    "stylelint-order": "^5.0.0",
    "stylelint-scss": "^4.0.0"
  }
}
